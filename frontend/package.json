{
  "name": "quant-office-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "QuantOffice 前端 — 纯前端像素风 SPA（Vite + React + TypeScript）",
  "packageManager": "bun@1.1.34",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun x vite",
    "build": "bun x vite build",
    "preview": "bun x vite preview",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x eslint src --ext .ts,.tsx",
    "format": "bun x prettier --write \"src/**/*.{ts,tsx,css}\"",
    "clean": "rm -rf dist node_modules .vite bun.lockb"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.5",
    "@tanstack/react-query": "^5.51.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.0"
  }
}
