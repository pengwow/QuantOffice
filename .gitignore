.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# 虚拟环境
.venv/
venv/
env/

# uv
uv.lock.sha256
.uv-cache/

# Node / 前端
node_modules/
frontend/dist/
frontend/.vite/
frontend/node_modules/
frontend/bun.lockb
