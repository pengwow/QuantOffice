# bun 1.2+ global cache (literal tilde dir under frontend; \ escapes ~ in fnmatch)
frontend/[\~]/
frontend/.bun/

# 构建产物（后端静态目录，部署时由 CI 重建）
quant_office/static/

# 数据（运行时数据目录，与源代码 quant_office/data/ 区分）
/data/
*.db
*.sqlite
*.sqlite3

# 日志
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

